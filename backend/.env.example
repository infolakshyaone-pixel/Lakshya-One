# =============================================================================
# Lakshya One Backend — Environment Variables (copy to .env)
# Never commit real secrets. Set these in Render/Railway dashboard.
# =============================================================================

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
# Render/Railway inject PORT automatically in production
PORT=4000

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Always use sslmode=require for Neon in production
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ─── JWT (backend API auth — keep secret, never expose to frontend) ───────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# ─── CORS (frontend origin — HTTPS in production, no trailing slash) ──────────
# Multiple origins: comma-separated (e.g. https://app.vercel.app,https://www.example.com)
FRONTEND_URL=http://localhost:3000

# ─── Email (Brevo) ─────────────────────────────────────────────────────────
# Get API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-your_brevo_api_key_here
# Must be a verified sender in Brevo
# Format: "Display Name <email@yourdomain.com>"
EMAIL_FROM=Lakshya One <noreply@yourdomain.com>

# ─── SMS / OTP (Fast2SMS) ───────────────────────────────────────────────────
# Get API key from https://www.fast2sms.com/dashboard
# If not set: OTP printed to console in development, not sent in production
# Note: phone OTP endpoints exist but are not yet wired up in the frontend
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ─── First-time admin setup (one-time seeder: npm run seed:admin) ─────────────
# Used only to create the initial platform admin account. Remove or rotate after use.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# ─── Optional ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
# Set to true when running behind Render/Railway/nginx (auto-enabled when NODE_ENV=production)
TRUST_PROXY=true

SENTRY_DSN=xxxxxxxxxxxxxxx